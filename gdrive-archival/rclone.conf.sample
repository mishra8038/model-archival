# Copy to rclone.conf and fill in your OAuth token (rclone config).
# Remote name must be "gdrive". To use a specific Drive folder as root, set root_folder_id.
# Folder for this project: 1HK8Ug4FZWXxk08A_nWGJ-iyHTcFkl6Gt

[gdrive]
type = drive
scope = drive
token = {"access_token":"...","token_type":"Bearer",...}
root_folder_id = 1HK8Ug4FZWXxk08A_nWGJ-iyHTcFkl6Gt

# Alternatively, omit root_folder_id and use remote as "gdrive:1HK8Ug4FZWXxk08A_nWGJ-iyHTcFkl6Gt"
# in config.yaml (already set) so uploads go to that folder by path.
